    .a0 = ¿No te parece que nuestra aldea es la mejor?
    .a1 = ¡Bienvenido a { $site }!
    .a2 = { $site } es una buena aldea en la que vivir.
# NPC reactions
npc-speech-night =
    .a0 = ¡Las linternas son útiles para viajar cuando es de noche!
    .a1 = Espero que estemos solos en esta oscuridad...
    .a2 = ¡Bu!
npc-speech-merchant_reject_sell_item =
    .a0 = No estoy dispuesto a vender ese objeto.
    .a1 = No, no puedes llevarte eso.
npc-speech-merchant_reject_buy_item =
    .a0 = No estoy dispuesto a comprar ese objeto.
    .a1 = No, no estoy interesado en eso.
npc-speech-merchant_trade_balance = Eso solo cubre el { $percentage }% de mis gastos!
npc-speech-villager_witch_alarm =
    .a0 = ¡Tengan cuidado! ¡Hay una bruja a la fuga!
    .a1 = ¡A las armas! ¡Hay una bruja entre nosotros!
    .a2 = ¡Cómo se atreven las brujas a atacar nuestro pueblo!
    .a3 = ¡Muerte a todas las brujas!
    .a4 = Las brujas no serán toleradas aquí.
    .a5 = ¡Bruja vil!
    .a6 = ¡Prueba el filo de mi espada, bruja asquerosa!
    .a7 = ¡Tus artes oscuras me repugnan!
    .a8 = ¡No dejen que la bruja los atrape!
    .a9 = ¡Las maldades de esta bruja están a punto de acabarse!
    .a10 = ¡Esta bruja es mía!
    .a11 = ¡Preparate para conocer a tu creador, maldita bruja!
    .a12 = ¡Veo una bruja! ¡Atrápenla!
    .a13 = ¡Veo una bruja! ¡Quemenla!
    .a14 = ¡Veo una bruja! ¡No dejen que escape!
    .a15 = ¡¿Qué horribles pociones elaborarás con tus tritones y limos?!
    .a16 = ¡Gente como tú debe arder en la hoguera!
    .a17 = ¡Muere bruja!
    .a18 = ¡Nunca más infundirás el miedo entre nuestros niños!
    .a19 = ¡Esto es por todo lo que has hecho!
    .a20 = No tratamos bien a tu tipo por aquí.
    .a21 = ¡Debiste quedarte en los fosos del infierno!
npc-speech-merchant_busy_trading =
    .a0 = Por favor, espera, solo soy una persona.
    .a1 = Un momento, déjame terminar.
    .a2 = Estoy ocupado, vuelve más tarde.
npc-speech-merchant_busy_combat =
    .a0 = ¡Espera, estoy en medio de esto!
    .a1 = ¡No puedo comerciar ahora, tengo enemigos con los que lidiar!
    .a2 = ¡Atrás, estoy ocupado luchando por mi vida!
npc-response-decline_hire =
    .a0 = Lo siento, ahora no tengo tiempo.
    .a1 = No gracias, lo siento.
npc-dialogue-hire_cancelled = Está bien, ¡hasta luego!
npc-dialogue-hire_expired =
    .a0 = Es hora de que deje tu servicio. ¡Nos vemos!
    .a1 = Mi servicio ha terminado, seguiré mi camino ahora. ¡Adiós!
npc-dialogue-hire_cancelled_unhappy = No puedo seguir trabajando para ti con la conciencia tranquila. Adiós.
npc-response-no_problem = ¡No hay problema! nos vemos luego.
npc-response-like_you =
    .a0 = ¡Me agradas!
    .a1 = Pareces un buen amigo.
    .a2 = Creo que eres amigable.
npc-response-doesnt_exist = No tenemos uno por estas tierras.
npc-speech-witness_theft =
    .a0 = ¡Eso no es tuyo!
    .a1 = Mantén tus manos alejadas.
    .a2 = ¡No toques eso!
    .a3 = ¡Ladrón!
    .a4 = Devuelve eso.
    .a5 = ¿Qué crees que estás haciendo?
    .a6 = Detente o llamaré a los guardias.
npc-speech-witness_theft_owned =
    .a0 = ¡Oye! Eso es mío.
    .a1 = ¿Por qué estás tocando mis cosas?
    .a2 = No eres bienvenido aquí si me quitas mis cosas.
npc-speech-thank_you =
    .a0 = ¡Gracias!
    .a1 = Gracias
npc-speech-pilot-takeoff =
    .a0 = ¡Adelante hacia { $dst }!
    .a1 = ¡Allá vamos!
    .a2 = ¡Próxima parada, { $dst }!
    .a3 = ¡Adiós, { $src }!
npc-speech-pilot-announce_next =
    .a0 = ¡Súbete si te diriges al { $dir } a { $dst }!
