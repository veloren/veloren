    .desc =
        Golpea a tu enemigo con un golpe contundente en la cabeza; el efecto aturdidor será mayor si está bloqueando.
        Entra en postura robusta.
common-abilities-sword-heavy_cross_cut = Tajo Cruzado Pesado
