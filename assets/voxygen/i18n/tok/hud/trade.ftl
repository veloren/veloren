hud-trade-trade_window = esun
hud-trade-phase1_description =
    o luka e ijo esun
     tawa poki.
hud-trade-phase2_description =
    ni la esun li awen.
     sina ken lukin sin e ona.
hud-trade-phase3_description = esun li pali.
hud-trade-persons_offer = pana tan { $playername }
hud-trade-has_accepted =
    { $playername }
    li wile
hud-trade-accept = wile
hud-trade-decline = ala
hud-trade-invite_sent = sina toki e wile esun tawa { $playername }.
hud-trade-invite-accepted = { $target } li kama esun tawa sina.
hud-trade-invite-declined = { $target } li wile ala esun tawa sina.
hud-trade-invite-timed_out = wile esun tawa { $target } li pini tan tenpo.
hud-trade-result-completed = esun li pini pona.
hud-trade-result-declined = esun li kama ala.
hud-trade-buy =
    kama jo: { $coin_num ->
        [1] mani wan
       *[other] mani { $coin_formatted }
    }
hud-trade-sell =
    pana: { $coin_num ->
        [1] mani wan
       *[other] mani { $coin_formatted }
    }
hud-trade-your_offer = pana sina
hud-trade-their_offer = pana ona
hud-trade-amount_input = o luka e ijo
hud-confirm-trade-for-nothing = sina wile ala wile pana e ijo ni, li kama jo e ala?
hud-trade-player_who = jan { $player_who }
