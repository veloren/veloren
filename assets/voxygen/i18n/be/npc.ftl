# NPC reactions
npc-speech-witness_murder =
    .a0 = Забойца!
    .a1 = Як ты мог гэта зрабіць?
    .a2 = Ааааа!
# NPC reactions
npc-speech-witness_death =
    .a0 = Не!
    .a1 = Гэта жахліва!
    .a2 = А божухна!
    .a3 = Свет стаў крыху цямнейшым.
# NPC reactions
npc-speech-night =
    .a0 = Ліхтары зручныя каб перамяшчацца ноччу!
    .a1 = Я спадзяюся, што мы адны ў цемры...
    .a2 = Бу!
# Generic NPC messages
npc-speech-merchant_trade_cancelled_hostile =
    .a0 = Прабачце што перапыняю, але ў нас ёсць праблема, якую трэба вырашыць!
    .a1 = Мы пагандлюем пазней, спачатку трэба паклапаціцца пра гэта!
# Generic NPC messages
npc-speech-moving_on =
    .a0 = Я дастаткова выдаткаваў часу тут, пара адпраўляцца ў { $site }!
    .a1 = Спадзяюся, я змагу знайсці дырыжабль, які ляціць у { $site }.
# Generic NPC messages
npc-speech-night_time =
    .a0 = Цёмна, яас вяртацца да хаты.
    .a1 = Я стаміўся.
    .a2 = Ложак вабіць мяне!
    .a3 = Дзякуй Богу, у мяне ёсць мой ліхтар!
# Generic NPC messages
npc-speech-day_time =
    .a0 = Пачынаецца новы дзень!
    .a1 = Ніколі не любіў прачынацца...
# Generic NPC messages
npc-speech-start_hunting =
    .a0 = Час палявання!
    .a1 = Маленькія жывёлы пакідаюць жывёльныя шкуры.
# Generic NPC messages
npc-speech-merchant_sell_undirected =
    .a0 = Усе мае тавары найвышэйшай якасці!
    .a1 = Хто-небудзь хоча купіць мае тавары?
    .a2 = У мяне лепшыя прапановы ў горадзе.
    .a3 = Шукаеш прыпасы? Я цябе пакрыю.
# Direction hints, used ONLY in npc-speech-tell* above
npc-speech-dir_north = поўначы
# Generic NPC messages
npc-speech-ambush =
    .a0 = Неразумна падарожнічаць аднаму!
    .a1 = Як скрасці цукерку ў дзіцяці!
    .a2 = Пакажы, што ў цябе ў кішэнях!
# Generic NPC messages
npc-speech-villager_busy =
    .a0 = Выбачай, я не магу размаўляць з табой зараз.
    .a1 = Паразмаўляем пазней, я заняты.
    .a2 = Няўжо ты не бачыш, што я нешта раблю?
# NPC reactions
npc-speech-welcome-aboard =
    .a0 = Вітаем на борце!
    .a1 = Магу я пабачыць ваш квіток?... Проста жартую, гэта бясплатна!
    .a2 = Прыемнай паездкі!
# Generic NPC messages
npc-speech-migrating =
    .a0 = Мне больш не прыемна жыць тут. Прыйшоў час пераехаць у { $site }.
    .a1 = Прыйшоў час рухацца да { $site }, мне абрыдла гэтае месца.
# Generic NPC messages
npc-speech-merchant_sell_directed =
    .a0 = Ты, там! Цябе патрэбен новы як-яго-там?
    .a1 = Ты галодны? Я ўпэўнены, што ў мяне ёсьць сыр які ты можаш купіць.
    .a2 = Ты выглядаеш так, быццам бы цябе спатрэбіліся новыя даспехі!
# NPC site hints
# Available variables:
# - $dir references npc-speech-dir-* variables below
# - $dist references npc-speech-dist-* variables below
# - $site represents hard-coded site in the world
npc-speech-tell_site =
    .a0 = Ты быў у { $site }? Гэта на { $dir } адсюль!
    .a1 = Табе варта як небудзь наведаць { $site }.
    .a2 = Калі прайсці { $dist } на { $dir }, то можна патрапіць у { $site }.
    .a3 = Хэй, на { $dir } ты знойдзеш { $site }, гэта { $dist }.
# Generic NPC messages
npc-speech-guard_thought =
    .a0 = Мой брат змагаецца з ограмі. Што выбраў я? Каравульную службу...
    .a1 = Яшчэ адзін патруль, і потым я змагу адправіцца да хаты.
    .a2 = Ніякім бандытам мяне не абысці.
    .a3 = Мне трэба навучыцца біць і не атрымваць шкоды.
    .a4 = Мне трэба трэніравацца пазбягаць удараў у вольны час.
# NPC monster hints
# Available variables:
# - $dir references npc-speech-dir-* variables below
# - $dist references npc-speech-dist-* variables below
# - $body references body-npc-speech-* variables in `body` component
npc-speech-tell_monster =
    .a0 = Кажуць, што { $body } знаходзіцца на { $dir }, { $dist }...
    .a1 = Лічыш сабе крутым? На { $body } ёсць { $dir }.
# NPC proposals
npc-speech-arena = Давай сядзім там!
# NPC reactions
npc-speech-witness_enemy_murder =
    .a0 = Мой Герой!
    .a1 = Нарэшце нехта зрабіў гэта!
    .a2 = Ура!
npc-speech-merchant_busy_trading =
    .a0 = Калі ласка, пачакай, я ж адзін.
    .a1 = Хвілінку, дай мне скончыць.
    .a2 = Я заняты, вярніся пазней.
npc-speech-merchant_busy_combat =
    .a0 = Пачакай, я ж яшчэ ня скончыў!
    .a1 = Зараз гандляваць не магу, трэба разбірацца з ворагамі!
    .a2 = Адчапіся, я змагаюся за сваё жыццё!
npc-speech-merchant_reject_sell_item =
    .a0 = Я не збіраюся прадаваць гэты тавар.
    .a1 = Не, у цябе гэтага не будзе.
npc-speech-merchant_reject_buy_item =
    .a0 = Я не гатовы купіць гэты тавар.
    .a1 = Не, мяне гэта не цікавіць.
npc-speech-merchant_trade_balance = Гэта пакрывае толькі { $percentage }% маіх выдаткаў!
npc-speech-villager_witch_alarm =
    .a0 = Сцеражыцеся! З'явілася вядзьмарка!
    .a1 = Да зброі! Сярод нас вядзьмарка!
    .a2 = Як культысты адважыліся напасці на нашу вёску!
    .a3 = Смерць усім вядзьмаркам!
    .a4 = Мы не станем трываць тут вядзьмарак!
    .a5 = Гадкая вядзьмарка!
    .a6 = Пакаштуй вострае лязо майго меча, ты, брудная вядзьмарка!
    .a7 = Твая чорная магія мяне агідзіць!
    .a8 = Не дазваляй вядзьмарцы схапіць тваё цела!
    .a9 = Злачынства гэтай вядзьмаркі вось-вось скончацца!
    .a10 = Гэтая вядзьмарка мая!
    .a11 = Рыхтуйся сустрэць свайго стваральніка, паскудны культыст!
    .a12 = Я бачу вядзьмарку! Хваціце яе!
    .a13 = Я бачу вядзьмарку! Спаліце яе!
    .a14 = Я бачу вядзьмарку! Не дазвольце ёй ўцячы!
    .a15 = Якія ж жахлівыя зелля ты гатуеш са сваіх вядзьмарскіх рапух і слізі?!
    .a16 = Такія, як ты, павінны гарэць на вогнішчы!
    .a17 = Умры, вядзьмарка!
    .a18 = Ты больш ня будзеш сеяць страх сярод нашых дзяцей!
    .a19 = Вось табе за ўсё, што ты нарабіла!
    .a20 = У нас тут ня любяць такіх як ты.
    .a21 = Табе трэба было заставацца ў падземным свеце!
npc-speech-villager_pirate_alarm =
    .a0 = Сцеражыцеся! З'явіўся пірат!
    .a1 = Да зброі! Сярод нас пірат!
    .a2 = Як гэтыя піраты смеюць нападаць на нашу вёску!
    .a3 = Смерць гэтым паскудным злыдням!
    .a4 = Мы не станем трываць тут піратаў!
    .a5 = Паскудны пірат!
    .a6 = Пакаштуй лязо майго мяча, брудны пірат!
    .a7 = Назад у акіян!
    .a8 = Абараняйце свае гаманцы!
    .a9 = Такіх, як ты, трэба вешаць!
    .a10 = Гэты пірат мой!
    .a11 = Рыхтуйся сустрэць свайго стваральніка, паскудны піраце!
    .a12 = Я бачу піратскую вартавую! Забіце іх, пакуль яны не данеслі!
    .a13 = Я бачу пірата! Не дайце яму ўцячы!
    .a14 = Павярні скарб, які ты скраў!
    .a15 = Такіх, як ты, трэба скормліваць акулам!
    .a16 = Памры, пірат!
    .a17 = Вось табе за ўсё, што ты нарабіў!
    .a18 = У нас тут ня любяць такіх, як ты.
    .a19 = Табе варта было застацца ў той сваёй разбітай лодцы, якую ты караблём клічаш!
npc-speech-remembers-fight = { $name }! Як ты смееш ізноў пераходзіць мне дарогу!
npc-speech-remembers-fight-no-name = Ты! Як смееш ізноў пераходзіць мне дарогу!
npc-speech-seeking_shelter_rain = Пачынаецца дождж, трэба знайсці сховішча.
npc-speech-rain_stopped = Дождж спыніўся, давайце працягнем!
npc-speech-wait_for_me =
    .a0 = Пачакай мяне!
    .a1 = Ты рухаешся занадта хутка для мяне!
    .a2 = Дай мне шанец нагнаць!
npc-goodbye =
    .a0 = Пабачымся пазней!
    .a1 = Да сустрэчы!
    .a2 = Да пабачэння!
    .a3 = Бывай!
npc-question-general =
    .a0 = Чым я магу табе дапамагчы?
    .a1 = Добрага дня. Што здарылася?
    .a2 = Вітаю, чым магу дапамагчы?
npc-info-current_site =
    .a0 = Гэта { $site }.
    .a1 = Ты ў { $site }.
npc-info-self_name =
    .a0 = Мяне клічуць { $name }.
    .a1 = Яны клічуць мяне { $name }.
    .a2 = { $name } маё імя.
npc-info-self_home =
    .a0 = Я жыву ў { $site }.
    .a1 = Мой дом гэта { $site }.
npc-info-self_homeless =
    .a0 = У мяне няма дома.
    .a1 = У мяне няма места якое я мог бы назваць домам.
npc-info-role =
    .a0 = Я { $role }.
    .a1 = Я працую { $role }.
    .a2 = Я па адукацыі { $role }.
noun-role-none =
    .a0 = Я вольны духам.
npc-info-unknown =
    .a0 = Я ня ведаю.
    .a1 = Я ня ўпэўнены.
npc-response-hire_time = Як надоўга вы хочаце мяне наняць?
npc-response-accept_hire =
    .a0 = Пойдзем!
    .a1 = Я гатовы, вядзі!
npc-response-decline_hire =
    .a0 = Прабач, у мяне зараз няма часу.
    .a1 = Не, дзякуй, прабач.
npc-response-already_hired = Не дуры, ты ж ужо мяне наняў!
npc-dialogue-hire_cancelled = Добра, да пабачэння!
npc-dialogue-hire_expired =
    .a0 = Час мне пакінуць тваю службу. Пабачымся!
    .a1 = Мая служба скончылася, цяпер я пайду сваім шляхам. Да пабачэння!
npc-dialogue-hire_cancelled_unhappy = Я не магу працягваць працаваць на цябе з чыстым сумленнем . Бывай.
npc-dialogue-hire_arrive_tavern = Я крыху пасяджу ў { $tavern }, пабачымся пазней!
npc-response-no_problem = Няма праблем! Да пабачэння.
npc-response-quest-nothing =
    .a0 = Не зараз, прабач.
    .a1 = Ня зараз.
    .a2 = Мабыць пазней!
npc-response-quest-rejected =
    .a0 = Ай! Рабі, як хочаш.
    .a1 = Мне да халеры.
    .a2 = Жабракі ня могуць выбіраць. Перастань марнаваць мой час!
npc-response-quest-reward =
    .a0 = Вось твая ўзнагарода.
    .a1 = Вось аплата за твае намаганні.
npc-response-quest-timeout =
    .a0 = У цябе скончыўся час, наша здзелка скасаваная!
    .a1 = Час скончыўся, грошай ня будзе!
npc-response-quest-escort-ask =
    .a0 = Ці можаш ты давесці мяне да { $dst }? Я заплачу табе { $coins } манет! Мне трэба туды дабрацца за { $mins } хвілін!
    .a1 = Я хачу патрапіць у { $dst } за { $mins } хвілін. Ці не мог бы ты саправадзіць мяне туды за { $coins } манет?
npc-response-quest-escort-start =
    .a0 = Ну што ж, вядзі! Я пазначыў гэтае месца на тваёй мапе.
    .a1 = Выдатна. Ты знойдзеш метку на сваёй мапе. Ідзі першы, я пайду за табой.
npc-response-quest-escort-where =
    .a0 = Мы накіроўваемся ў { $dst }.
    .a1 = Я спрабую дабрацца да { $dst }.
    .a2 = Мы ж ідзем у { $dst }, так?
npc-response-quest-escort-complete =
    .a0 = Мы прыбылі. Дзякуй!
    .a1 = Дзякуй, што прывеў мяне сюды. Да пабачэння!
npc-response-quest-slay-ask =
    .a0 = Людзей тут тэрарызуе { $body }! Яго трэба забіць! Я заплачу табе { $coins } манет за гэтую працу.
    .a1 = Недалёка адсюль падсцерагае { $body }. Мы не можам так жыць! Мы прапануем { $coins } манет, калі ты выканаеш гэтую справу!
npc-response-quest-slay-start =
    .a0 = Я пазначыў на тваёй мапе апошняе вядомае месцазнаходжанне пачвары.
    .a1 = Я пазначыў на тваёй мапе, куды ісці.
npc-response-quest-slay-start_2 = Калі ты ня можаш мяне знайсці, ты можаш спытаць дарогу ў каго-небудзь іншага.
npc-response-quest-slay-start_3 =
    .a0 = Сцеражыся! Пачвара рухаецца і можа не затрымацца тут надоўга. Распытай мясцовых, калі след застыне!
    .a1 = Істота не прабудзе тут доўга. Калі вы згубіце яе з вачэй, спытайце ў мясцовых, дзе яна.
npc-response-quest-slay-start_4 =
    .a0 = Вярніся да мяне, калі справа будзе зроблена, і ты атрымаеш сваю плату.
    .a1 = Шчаслівай дарогі! Твая аплата чакае цябе, калі вернешся да мяне!
npc-response-quest-slay-where = Я абнавіў месціва монстра на тваёй мапе.
npc-response-quest-slay-thanks =
    .a0 = Дзякуй! Людзі тут зноў будуць у бяспецы.
    .a1 = Мая ўдзячнасць... і мае грошы!
    .a2 = Вы зрабілі нам велізарную ласку, вялікі дзякуй.
npc-response-like_you =
    .a0 = Ты мне падабаешся!
    .a1 = Здаецца, ты добры сябар.
    .a2 = Я думаю, што ты прыязны.
npc-response-ambivalent_you =
    .a0 = Добра выглядаеш.
    .a1 = Насамрэч, у мяне няма ніякіх моцных пачуццяў.
npc-response-dislike_you =
    .a0 = Ты мне не падабаешся.
    .a1 = Ты выглядаеш ня вельмі прыязна.
npc-question-directions =
    .a0 = Куды ты хочаш пайсці?
    .a1 = Што ты шукаеш?
npc-response-directions = Я пазначыў на тваёй мапе. Поспехаў!
npc-response-doesnt_exist = У нас тут такога няма.
npc-speech-witness_theft =
    .a0 = Гэта не тваё!
    .a1 = Трымай рукі пры сабе.
    .a2 = Не чапай гэта!
    .a3 = Злодзей!
    .a4 = Вярні гэта.
    .a5 = Што ты робіш?
    .a6 = Спыніся, а тое я паклічу ахову.
npc-speech-witness_theft_owned =
    .a0 = Гэй! Гэта маё.
    .a1 = Чаму ты чапаеш мае рэчы?
    .a2 = Табе тут не рады, калі ты бярэш маё.
npc-speech-thank_you =
    .a0 = Дзякуй!
    .a1 = Дзякуй
npc-speech-reject_rival =
    .a0 = Табе тут не рады.
    .a1 = Прабач, я не хачу з табой размаўляць.
    .a2 = Табе варта сысці.
npc-speech-where_are_we_going_wrong_profession =
    .a0 = Чакай, што? Я не думаю, што павінен куды-небудзь цябе везці.
    .a1 = Гм? Навошта мне кудысьці цябе везці?
npc-speech-pilot-takeoff =
    .a0 = Наперад да { $dst }!
    .a1 = Паляцелі!
    .a2 = Наступны прыпынак, { $dst }!
    .a3 = Бывай, { $src }!
npc-speech-pilot-landed =
    .a0 = Яшчэ адна паспяховая пасадка.
    .a1 = Павольней...
    .a2 = Цудоўная праца.
    .a3 = Гэта твой прыпынак?
npc-speech-pilot-announce_next =
    .a0 = Садзіцеся, калі вы накіроўваецеся з { $dir } у { $dst }!
    .a1 = Мы хутка адпраўляемся ў { $dst }!
    .a2 = Ляціце ў { $dir }? Скачыце на борт!
npc-speech-pilot-where_heading_now =
    .a0 = Мы накіроўваемся з { $dir } у { $dst }! Пасля гэтага мы накіроўваемся з { $ndir } у { $ndst }.
    .a1 = Спачатку я вязу нас з { $dir } у { $dst }, а потым з { $ndir } у { $ndst }.
    .a2 = Спачатку мы ляцім з { $dir } у { $dst }, а потым накіруемся з { $ndir } у { $ndst }.
npc-speech-pilot-unknown_destination =
    .a0 = Я насамрэч ня ўпэўнены, куды мы ляцім.
    .a1 = На жаль, я ўжо ня ведаю, куды мы рухаемся...
    .a2 = Неяпамятаю! Прабач.
npc-speech-pirate =
    .a0 = Аррр!
    .a2 = Сябры, давайце весяліцца!
    .a3 = Што мы будзем рабіць з п'яным мараком~
npc-speech-pirate_raid =
    .a0 = Хадзем разам са мной рабаваць { $site }.
    .a1 = Абкрадзі { $site }, браценік.
    .a2 = Мы парабуем { $site }.
npc-signs-keep_out = Не ўваходзіць!
