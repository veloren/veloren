# Agility
buff-agility = Спрыт
    .desc =
        Вы перамяшчаецеся хутчэй, 
        але наносіце меньш шкоды, і атрымліваеце больш шкоды.
    .stat =
        { $duration ->
            [one]
                Павялічвае хуткасць бегу на { $strength } %.
                Сіла атакі і абароны кардынальна памяншаюцца.
                Дзейнічае ў плыні 1 сякунды.
            [few]
                Павялічвае хуткасць бегу на { $strength } %.
                Сіла атакі і абароны кардынальна памяншаюцца.
                Дзейнічае ў плыні { $duration } сякунд.
            [many]
                Павялічвае хуткасць бегу на { $strength } %.
                Сіла атакі і абароны кардынальна памяншаюцца.
                Дзейнічае ў плыні { $duration } сякунд.
           *[other]
                Increases movement speed by { $strength } %.
                Сіла атакі і абароны кардынальна памяншаюцца.
                Дзейнічае ў плыні { $duration } сякунды.
        }
