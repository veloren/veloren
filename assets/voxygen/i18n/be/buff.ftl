    .desc = Паступова аднаўляе здароўе
    .stat =
        { $duration ->
            [one] Аднаўляе  { $str_total } АЗ за { $duration } сякунду.
            [few] Аднаўляе  { $str_total } АЗ за { $duration } сякунды.
            [many] Аднаўляе  { $str_total } АЗ за { $duration } сякунд.
           *[other] Аднаўляе { $str_total } АЗ за { $duration } сякунду.
        }
