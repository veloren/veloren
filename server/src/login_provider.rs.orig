use crate::{
    Client,
    settings::{AdminRecord, Ban, Banlist, WhitelistRecord, banlist::NormalizedIpAddr},
};
use authc::{AuthClient, AuthClientError, AuthToken, Uuid};
use chrono::Utc;
use common::comp::{AdminRole, MAX_ALIAS_LEN};
use common_net::msg::RegisterError;
use hashbrown::HashMap;
use specs::Component;
use serde::Deserialize;
use std::{env, str::FromStr, sync::Arc, time::Duration};
use tokio::{runtime::Runtime, sync::oneshot};
use tracing::{error, info, warn};

/// Determines whether a user is banned, given a ban record connected to a user,
/// the `AdminRecord` of that user (if it exists), and the current time.
pub fn ban_applies(
    ban: &Ban,
    admin: Option<&AdminRecord>,
    now: chrono::DateTime<chrono::Utc>,
) -> bool {
    // Make sure the ban is active, and that we can't override it.
    //
    // If we are an admin and our role is at least as high as the role of the
    // person who banned us, we can override the ban; we negate this to find
    // people who cannot override it.
    let exceeds_ban_role = |admin: &AdminRecord| {
        AdminRole::from(admin.role) >= AdminRole::from(ban.performed_by_role())
    };
    !ban.is_expired(now) && !admin.is_some_and(exceeds_ban_role)
}

fn derive_uuid(username: &str) -> Uuid {
    let mut state = 144066263297769815596495629667062367629;

    for byte in username.as_bytes() {
        state ^= *byte as u128;
        state = state.wrapping_mul(309485009821345068724781371);
    }

    Uuid::from_u128(state)
}

/// derive Uuid for "singleplayer" is a pub fn
pub fn derive_singleplayer_uuid() -> Uuid { derive_uuid("singleplayer") }

pub struct PendingLogin {
    pending_r: oneshot::Receiver<Result<(String, Uuid), RegisterError>>,
}

impl PendingLogin {
    pub(crate) fn new_success(username: String, uuid: Uuid) -> Self {
        let (pending_s, pending_r) = oneshot::channel();
        let _ = pending_s.send(Ok((username, uuid)));

        Self { pending_r }
    }
}

impl Component for PendingLogin {
    type Storage = specs::DenseVecStorage<Self>;
}

#[derive(Clone)]
struct GlitchAuthConfig {
    api_base_url: String,
    title_id: String,
    title_token: String,
    shared_password: Option<String>,
    platform: String,
    game_version: String,
}

impl GlitchAuthConfig {
    fn from_provider_addr(addr: &str) -> Self {
        let api_base_url = env::var("GLITCH_API_BASE_URL").unwrap_or_else(|_| {
            let raw = addr
                .strip_prefix("glitch://")
                .unwrap_or("api.glitch.fun/api")
                .trim_end_matches('/');

            if raw.starts_with("http://") || raw.starts_with("https://") {
                raw.to_string()
            } else {
                format!("https://{}", raw)
            }
        });

        Self {
            api_base_url: api_base_url.trim_end_matches('/').to_string(),
            title_id: env::var("GLITCH_TITLE_ID")
                .expect("GLITCH_TITLE_ID is required when using glitch:// auth"),
            title_token: env::var("GLITCH_TITLE_TOKEN")
                .expect("GLITCH_TITLE_TOKEN is required when using glitch:// auth"),
            shared_password: env::var("GLITCH_SHARED_PASSWORD").ok(),
            platform: env::var("GLITCH_PLATFORM").unwrap_or_else(|_| "linux".to_string()),
            game_version: env::var("GLITCH_GAME_VERSION")
                .unwrap_or_else(|_| "veloren-glitch".to_string()),
        }
    }
}

#[derive(Deserialize)]
struct GlitchValidateResponse {
    valid: Option<bool>,
    user_name: Option<String>,
    reason: Option<String>,
    error: Option<String>,
}

enum AuthMode {
    Veloren(Arc<AuthClient>),
    Glitch(GlitchAuthConfig),
    None,
}

pub struct LoginProvider {
    runtime: Arc<Runtime>,
    auth_mode: AuthMode,
}

impl LoginProvider {
    pub fn new(auth_addr: Option<String>, runtime: Arc<Runtime>) -> Self {
        tracing::trace!(?auth_addr, "Starting LoginProvider");

        let auth_mode = match auth_addr {
            Some(addr) if addr.starts_with("glitch://") => AuthMode::Glitch(GlitchAuthConfig::from_provider_addr(&addr)),
            Some(addr) => {
                let (scheme, authority) = addr.split_once("://").expect("invalid auth url");

                let scheme = scheme
                    .parse::<authc::Scheme>()
                    .expect("invalid auth url scheme");
                let authority = authority
                    .parse::<authc::Authority>()
                    .expect("invalid auth url authority");

                AuthMode::Veloren(Arc::new(AuthClient::new(scheme, authority).expect("insecure auth scheme")))
            },
            None => AuthMode::None,
        };

        Self { runtime, auth_mode }
    }

    pub fn verify(&self, username_or_token: &str) -> PendingLogin {
        let (pending_s, pending_r) = oneshot::channel();

        match &self.auth_mode {
            // Token from Veloren auth server expected.
            AuthMode::Veloren(srv) => {
                let srv = Arc::clone(srv);
                let username_or_token = username_or_token.to_string();
                self.runtime.spawn(async move {
                    let _ = pending_s.send(Self::query_veloren(srv, &username_or_token).await);
                });
            },
            // Glitch mode expects "install_id:shared_password" from the client.
            // The install_id is the deterministic Glitch identity. The visible
            // Veloren alias is pulled from the Glitch validate response.
            AuthMode::Glitch(cfg) => {
                let cfg = cfg.clone();
                let username_or_token = username_or_token.to_string();
                self.runtime.spawn(async move {
                    let _ = pending_s.send(Self::query_glitch(cfg, &username_or_token).await);
                });
            },
            // Username is expected.
            AuthMode::None => {
                let username = username_or_token;
                let uuid = derive_uuid(username);
                let _ = pending_s.send(Ok((username.to_string(), uuid)));
            },
        }

        PendingLogin { pending_r }
    }

    pub(crate) fn login<R>(
        pending: &mut PendingLogin,
        client: &Client,
        admins: &HashMap<Uuid, AdminRecord>,
        whitelist: &HashMap<Uuid, WhitelistRecord>,
        banlist: &Banlist,
        player_count_exceeded: impl FnOnce(String, Uuid) -> (bool, R),
        make_ip_ban_upgrade: impl FnOnce(NormalizedIpAddr, Uuid, String),
    ) -> Option<Result<R, RegisterError>> {
        match pending.pending_r.try_recv() {
            Ok(Err(e)) => Some(Err(e)),
            Ok(Ok((username, uuid))) => {
                let now = Utc::now();
                // We ignore mpsc connections since those aren't to an external
                // process.
                let ip = client
                    .connected_from_addr()
                    .socket_addr()
                    .map(|s| s.ip())
                    .map(NormalizedIpAddr::from);
                // Hardcoded admins can always log in.
                let admin = admins.get(&uuid);
                if let Some(ban) = banlist
                    .uuid_bans()
                    .get(&uuid)
                    .and_then(|ban_entry| ban_entry.current.action.ban())
                    .into_iter()
                    .chain(ip.and_then(|ip| {
                        banlist
                            .ip_bans()
                            .get(&ip)
                            .and_then(|ban_entry| ban_entry.current.action.ban())
                    }))
                    .find(|ban| ban_applies(ban, admin, now))
                {
                    if let Some(ip) = ip
                        && ban.upgrade_to_ip
                    {
                        make_ip_ban_upgrade(ip, uuid, username.clone());
                    }

                    // Get ban info and send a copy of it
                    return Some(Err(RegisterError::Banned(ban.info())));
                }

                // non-admins can only join if the whitelist is empty (everyone can join)
                // or their name is in the whitelist.
                if admin.is_none() && !whitelist.is_empty() && !whitelist.contains_key(&uuid) {
                    return Some(Err(RegisterError::NotOnWhitelist));
                }

                // non-admins can only join if the player count has not been exceeded.
                let (player_count_exceeded, res) = player_count_exceeded(username, uuid);
                if admin.is_none() && player_count_exceeded {
                    return Some(Err(RegisterError::TooManyPlayers));
                }

                Some(Ok(res))
            },
            Err(oneshot::error::TryRecvError::Closed) => {
                error!("channel got closed to early, this shouldn't happen");
                Some(Err(RegisterError::AuthError(
                    "Internal Error verifying".to_string(),
                )))
            },
            Err(oneshot::error::TryRecvError::Empty) => None,
        }
    }

    async fn query_veloren(
        srv: Arc<AuthClient>,
        username_or_token: &str,
    ) -> Result<(String, Uuid), RegisterError> {
        info!(?username_or_token, "Validating token");
        // Parse token
        let token = AuthToken::from_str(username_or_token)
            .map_err(|e| RegisterError::AuthError(e.to_string()))?;
        // Validate token
        match async {
            let uuid = srv.validate(token).await?;
            let username = srv.uuid_to_username(uuid).await?;
            let r: Result<_, AuthClientError> = Ok((username, uuid));
            r
        }
        .await
        {
            Err(e) => Err(RegisterError::AuthError(e.to_string())),
            Ok((username, uuid)) => Ok((username, uuid)),
        }
    }

    async fn query_glitch(
        cfg: GlitchAuthConfig,
        username_or_token: &str,
    ) -> Result<(String, Uuid), RegisterError> {
        let (install_id, supplied_password) = username_or_token
            .split_once(':')
            .unwrap_or((username_or_token, ""));

        if install_id.trim().is_empty() {
            return Err(RegisterError::AuthError("Missing Glitch install_id".to_string()));
        }

        if let Some(expected) = cfg.shared_password.as_deref().filter(|s| !s.is_empty()) {
            if supplied_password != expected {
                return Err(RegisterError::AuthError("Invalid Glitch shared password".to_string()));
            }
        }

        info!(?install_id, "Validating Glitch install");

        let http = reqwest::Client::builder()
            .timeout(Duration::from_secs(8))
            .build()
            .map_err(|e| RegisterError::AuthError(format!("Glitch HTTP client failed: {}", e)))?;

        let validate_url = format!(
            "{}/titles/{}/installs/{}/validate",
            cfg.api_base_url, cfg.title_id, install_id
        );

        let response = http
            .post(&validate_url)
            .bearer_auth(&cfg.title_token)
            .json(&serde_json::json!({}))
            .send()
            .await
            .map_err(|e| RegisterError::AuthError(format!("Glitch validate request failed: {}", e)))?;

        let status = response.status();
        let body = response.text().await.unwrap_or_default();
        let parsed = serde_json::from_str::<GlitchValidateResponse>(&body).ok();
        let valid = parsed.as_ref().and_then(|r| r.valid).unwrap_or(status.is_success());

        if !status.is_success() || !valid {
            let reason = parsed
                .as_ref()
                .and_then(|r| r.reason.as_ref().or(r.error.as_ref()))
                .cloned()
                .unwrap_or_else(|| body.clone());
            return Err(RegisterError::AuthError(format!("Glitch access denied: {}", reason)));
        }

        let raw_glitch_username = parsed
            .as_ref()
            .and_then(|r| r.user_name.as_deref())
            .map(str::trim)
            .filter(|name| !name.is_empty())
            .unwrap_or(install_id);

        let veloren_alias = Self::normalize_glitch_alias(raw_glitch_username, install_id);

        // Create/resume the install and record the first heartbeat immediately after login.
        // Later heartbeat calls should be emitted by the Glitch launcher or a small sidecar.
        // Keep sending the Glitch username back for analytics/display consistency, while
        // the Veloren runtime uses the sanitized alias returned below.
        let install_url = format!("{}/titles/{}/installs", cfg.api_base_url, cfg.title_id);
        let heartbeat_body = serde_json::json!({
            "user_install_id": install_id,
            "session_id": install_id,
            "user_name": raw_glitch_username,
            "platform": cfg.platform,
            "device_type": "linux_server",
            "operating_system": "linux",
            "game_version": cfg.game_version,
            "referral_source": "glitch"
        });

        if let Err(e) = http
            .post(&install_url)
            .bearer_auth(&cfg.title_token)
            .json(&heartbeat_body)
            .send()
            .await
        {
            warn!(?install_id, error = ?e, "Glitch heartbeat failed after successful validation");
        }

        // IMPORTANT: Use the Glitch username as the visible Veloren alias, but keep
        // the deterministic UUID derived from install_id. That preserves saves and
        // progression if a Glitch display name changes later.
        Ok((veloren_alias, derive_uuid(install_id)))
    }

    fn normalize_glitch_alias(raw_name: &str, fallback_install_id: &str) -> String {
        let mut alias = raw_name
            .trim()
            .chars()
            .map(|c| {
                if c.is_alphanumeric() || c == '_' || c == '-' {
                    c
                } else {
                    '_'
                }
            })
            .collect::<String>();

        if alias.trim_matches('_').is_empty() {
            alias = fallback_install_id.to_string();
        }

        while alias.len() > MAX_ALIAS_LEN {
            alias.pop();
        }

        if alias.is_empty() {
            fallback_install_id.to_string()
        } else {
            alias
        }
    }

    pub fn username_to_uuid(&self, username: &str) -> Result<Uuid, AuthClientError> {
        match &self.auth_mode {
            AuthMode::Veloren(srv) => {
                //TODO: optimize
                self.runtime.block_on(srv.username_to_uuid(&username))
            },
            AuthMode::Glitch(_) | AuthMode::None => Ok(derive_uuid(username)),
        }
    }

    pub fn uuid_to_username(
        &self,
        uuid: Uuid,
        fallback_alias: &str,
    ) -> Result<String, AuthClientError> {
        match &self.auth_mode {
            AuthMode::Veloren(srv) => {
                //TODO: optimize
                self.runtime.block_on(srv.uuid_to_username(uuid))
            },
            AuthMode::Glitch(_) | AuthMode::None => Ok(fallback_alias.into()),
        }
    }
}
